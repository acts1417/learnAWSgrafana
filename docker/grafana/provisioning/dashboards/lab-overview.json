{
  "title": "Lab Overview — GPU, System, BOINC",
  "uid": "lab-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "GPU Utilization %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nvidia_smi_utilization_gpu_ratio * 100",
          "legendFormat": "GPU {{uuid}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "GPU Memory Used",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "nvidia_smi_memory_used_bytes",
          "legendFormat": "Used"
        },
        {
          "expr": "nvidia_smi_memory_total_bytes",
          "legendFormat": "Total (16 GB)"
        }
      ]
    },
    {
      "id": 3,
      "title": "GPU Temperature (°C)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 90,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 83 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nvidia_smi_temperature_gpu",
          "legendFormat": "GPU Temp"
        }
      ]
    },
    {
      "id": 4,
      "title": "GPU Power Draw (W)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "max": 70,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 65 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nvidia_smi_power_draw_watts",
          "legendFormat": "Power"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Utilization %",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 6,
      "title": "RAM Utilization %",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 6 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ]
    },
    {
      "id": 7,
      "title": "CPU & RAM over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by(instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        },
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk Usage %",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "datasource": null,
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)",
          "legendFormat": "/ (root)"
        }
      ]
    }
  ]
}
